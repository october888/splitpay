# Hex-encoded private key of the deploying account, WITHOUT a 0x prefix is fine.
# DO NOT commit this file. The deployer needs Arc-testnet USDC for gas
# (faucet: https://faucet.circle.com).
DEPLOYER_PRIVATE_KEY=

# RPC overrides (optional). Defaults are the public Arc endpoints.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_MAINNET_RPC_URL=
ARC_MAINNET_CHAIN_ID=1243

# USDC ERC-20 address on the target network. The default is the Arc system
# USDC address, which works on both Arc testnet and (eventually) Arc mainnet.
USDC_ADDRESS=0x3600000000000000000000000000000000000000
