{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["node", "mocha"]
  },
  "include": ["./scripts/**/*.ts", "./test/**/*.ts", "./hardhat.config.ts"]
}
